    <!--
      ═══════════════════════════════════════════════════════════════
        RED GATES — 10 inline gate models
        Each gate = 4 bars forming a rectangular frame (approx 2.6m × 2.6m)
        Colour: bright red (#FF0000)
      ═══════════════════════════════════════════════════════════════
    -->
    <!-- Gate helper: each gate is a self-contained model with
         left post, right post, top bar, bottom bar, all red. -->

    <model name="gate_01">
      <static>true</static>
      <pose>3 0 2.0 0 0 0</pose>
      <link name="left">
        <pose>0 1.3 0 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 0.15 2.6</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 0.15 2.6</size></box></geometry></collision>
      </link>
      <link name="right">
        <pose>0 -1.3 0 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 0.15 2.6</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 0.15 2.6</size></box></geometry></collision>
      </link>
      <link name="top">
        <pose>0 0 1.3 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 2.6 0.15</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 2.6 0.15</size></box></geometry></collision>
      </link>
      <link name="bottom">
        <pose>0 0 -1.3 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 2.6 0.15</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 2.6 0.15</size></box></geometry></collision>
      </link>
    </model>

    <model name="gate_02">
      <static>true</static>
      <pose>7 3 2.5 0 0 0.3</pose>
      <link name="left">
        <pose>0 1.3 0 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 0.15 2.6</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 0.15 2.6</size></box></geometry></collision>
      </link>
      <link name="right">
        <pose>0 -1.3 0 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 0.15 2.6</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 0.15 2.6</size></box></geometry></collision>
      </link>
      <link name="top">
        <pose>0 0 1.3 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.1 2.6 0.15</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.1 2.6 0.15</size></box></geometry></collision>
      </link>
      <link name="bottom">
        <pose>0 0 -1.3 0 0 0</pose>
