<?xml version="1.0"?>
<!--
  aerial_nav.world — Gz Sim (Gazebo Harmonic) world for drone gate navigation.
  Uses X4 UAV Config 1 from Gazebo Fuel with front camera + velocity control.
-->
<sdf version="1.6">
  <world name="aerial_nav_world">

    <!-- ═══ Physics ═══ -->
    <physics name="4ms" type="ignored">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>

    <!-- ═══ Required Gz Sim System Plugins ═══ -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics">
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu">
    </plugin>
    <plugin filename="gz-sim-contact-system"
            name="gz::sim::systems::Contact">
    </plugin>

    <!-- ═══ Lighting ═══ -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>
    <light name="fill_light" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.6 0.6 0.6 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>0.3 0.4 -1.0</direction>
    </light>
    <light name="interior_light_1" type="point">
      <pose>10 5 7 0 0 0</pose>
      <diffuse>0.9 0.8 0.6 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>30</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>
    <light name="interior_light_2" type="point">
      <pose>20 -2 7 0 0 0</pose>
      <diffuse>0.7 0.75 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>30</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- ═══ Ground Plane ═══ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Arena Floor ═══ -->
    <model name="arena_floor">
      <static>true</static>
      <pose>15 0 0.005 0 0 0</pose>
      <link name="floor_link">
        <visual name="visual">
          <geometry>
            <box><size>40 30 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.38 1</ambient>
            <diffuse>0.4 0.4 0.43 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>-8 -18 18 0 0.55 1.1</pose>
      </camera>
    </gui>

    <!-- ═══ Arena Walls ═══ -->
    <model name="wall_south">
      <static>true</static>
      <pose>15 -15 4 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>40 0.3 8</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.35 1</ambient>
            <diffuse>0.6 0.5 0.4 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>40 0.3 8</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="wall_north">
      <static>true</static>
      <pose>15 15 4 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>40 0.3 8</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.35 1</ambient>
            <diffuse>0.6 0.5 0.4 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>40 0.3 8</size></box></geometry>
        </collision>
      </link>
    </model>

